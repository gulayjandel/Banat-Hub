<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Logging Out - Banat Hub</title>
    <link rel="stylesheet" href="style.css">
    <style>
        .logout-box {
            text-align: center;
            margin-top: 100px;
            font-family: Arial, sans-serif;
        }
        .loader {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #e67e22;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="logout-box">
        <img src="images/629994626_1247707730623982_5654588655489087962_n.png" width="100">
        <h2>Logging you out...</h2>
        <div class="loader"></div>
        <p>Thank you for visiting Banat Hub!</p>
    </div>

    <script>
        // 1. Clear the data
        localStorage.removeItem('isLoggedIn');
        
        // 2. Wait 2 seconds so they can see the message, then redirect
        setTimeout(function() {
            window.location.href = 'login.html';
        }, 2000);
    </script>
</body>
</html>
